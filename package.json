{
  "name": "coaching-management-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm.cmd install --workspaces",
    "dev": "concurrently \"npm.cmd run dev --workspace backend\" \"npm.cmd run dev --workspace frontend\"",
    "dev:backend": "npm.cmd run dev --workspace backend",
    "dev:frontend": "npm.cmd run dev --workspace frontend",
    "build": "npm.cmd run build --workspace frontend",
    "seed:admin": "npm.cmd run seed:admin --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
